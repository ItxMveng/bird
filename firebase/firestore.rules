rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function transactionForDispute(txId) {
      return get(/databases/$(database)/documents/transactions/$(txId)).data;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'phone', 'role', 'isPro', 'status', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'active'
        && request.resource.data.isPro == false;
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role', 'status', 'isPro']);
      allow delete: if false;
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid);
      allow write: if false; // server-only via Cloud Functions/Admin SDK
    }

    match /wallet_transactions/{txId} {
      allow read: if isAuthenticated() && resource.data.walletId == request.auth.uid;
      allow write: if false;
    }

    match /auctions/{auctionId} {
      allow read: if true;
      allow create, update: if false; // backend-only to enforce domain invariants
      allow delete: if false;
    }

    match /bids/{bidId} {
      allow read: if isAuthenticated();
      allow create: if false; // backend-only via Cloud Functions
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow write: if false;
    }

    match /transaction_secrets/{transactionId} {
      allow read: if isAuthenticated() && resource.data.buyerId == request.auth.uid;
      allow write: if false;
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated()
        && (
          isAdmin()
          || transactionForDispute(resource.data.transactionId).buyerId == request.auth.uid
          || transactionForDispute(resource.data.transactionId).sellerId == request.auth.uid
        );
      allow create: if false; // backend-only via Cloud Functions
      allow update, delete: if false;
    }

    match /idempotency/{key} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
